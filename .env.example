# Falcon Gateway Environment Variables
# Copy to .env and update values for your environment

# PostgreSQL
POSTGRES_USER=falcon
POSTGRES_PASSWORD=falcon_secret
POSTGRES_DB=falcon
DB_HOST=falcon-postgresql
DB_PORT=5432

# PostgreSQL Exporter DSN
DATA_SOURCE_NAME=postgresql://falcon:falcon_secret@falcon-postgresql:5432/falcon?sslmode=disable

# Grafana
GF_SECURITY_ADMIN_PASSWORD=falcon123

# Environment label for Prometheus
ENVIRONMENT=dev

# Falcon Messenger
FALCON_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
FALCON_BLUESKY_HANDLE=your-handle.bsky.social
FALCON_BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
